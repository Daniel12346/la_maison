{% set showPrivateSection = form.date.vars.value ? (form.date.vars.value|date('N') in [5, 6]) : false %}

<div class="reservation-card" {{ attributes }}>
<!-- nakon podnošenja forme, korisnik će biti preusmjeren na stranicu za potvrdu -->
    {% form_theme form 'form/_errors_below_layout.html.twig' %}
    {{ form_start(form, {
        'action': path('reservation_submit'),
        'method': 'POST',
        'attr': {
            'data-action': 'submit->live#action:prevent',
            'data-live-action-param': 'save'
        }
    }) }}

    <div class="reservation-layout">
        <div class="form-main">
            <div class="form-row">
                <div>
                    {{ form_row(form.partySize) }}
                </div>
                <div>
                    {{ form_row(form.date, {'attr': {'data-reservation-date': 'true'}}) }}
                </div>
            </div>

            <div class="form-row">
                {% if form.timeSlot is defined %}
                    <div>
                        {{ form_row(form.timeSlot) }}
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="private-side"{% if not showPrivateSection %} style="display: none;"{% endif %}>
            {% if form.isPrivate is defined %}
                <div class="private-row">
                    {{ form_label(form.isPrivate) }}
                    {{ form_widget(form.isPrivate) }}
                    <span
                        class="info-icon"
                        role="button"
                        tabindex="0"
                        data-popover-text="Book the entire venue exclusively for your group. Available on Fridays & Saturdays for parties of 6-12 people."
                        aria-label="Private reservation info"
                    >i</span>
                </div>
                {{ form_errors(form.isPrivate) }}
            {% endif %}
        </div>
    </div>

    {{ form_rest(form) }}
    {{ form_end(form) }}
</div>
